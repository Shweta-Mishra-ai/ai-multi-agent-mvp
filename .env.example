# Required
OPENAI_API_KEY=sk-...

# Optional: use any OpenAI-compatible provider (Ollama, vLLM, ...)
# OPENAI_BASE_URL=http://localhost:11434/v1
# AGENTOS_MODEL=gpt-4o-mini

# Optional: better web search for the research agent (free tier at tavily.com)
# TAVILY_API_KEY=tvly-...

# Optional: real email sending for the email agent (otherwise drafts only)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=you@gmail.com

# Optional: storage locations
# AGENTOS_DB=agentos.db
# AGENTOS_WORKSPACE=workspace

# Optional: production tuning (defaults shown)
# AGENTOS_LLM_TIMEOUT=60          # seconds per LLM call
# AGENTOS_LLM_RETRIES=3           # automatic retries on rate limits / 5xx
# AGENTOS_RUN_TIMEOUT=300         # hard deadline per run (seconds)
# AGENTOS_MAX_PARALLEL=3          # concurrent agent steps
# AGENTOS_MAX_STEPS=5             # max plan steps per run
# AGENTOS_MAX_TOOL_TURNS=8        # max tool-loop turns per agent
# AGENTOS_MAX_INPUT_CHARS=4000    # request size limit
# AGENTOS_RATE_LIMIT_PER_MIN=10   # runs per minute for this deployment
# AGENTOS_LOG_LEVEL=WARNING
