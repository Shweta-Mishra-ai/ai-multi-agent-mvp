# Required
OPENAI_API_KEY=sk-...

# Optional: use any OpenAI-compatible provider (Ollama, vLLM, ...)
# OPENAI_BASE_URL=http://localhost:11434/v1
# AGENTOS_MODEL=gpt-4o-mini

# Optional: better web search for the research agent (free tier at tavily.com)
# TAVILY_API_KEY=tvly-...

# Optional: real email sending for the email agent (otherwise drafts only)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=you@gmail.com

# Optional: storage locations
# AGENTOS_DB=agentos.db
# AGENTOS_WORKSPACE=workspace
